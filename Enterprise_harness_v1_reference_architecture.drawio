vers   (behind Run Contract R3 · onboarded via W-C bake-off · A2/A4/A5)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#edfaf1;strokeColor=#82b366;verticalAlign=top;align=center;fontStyle=1;fontSize=13;fontColor=#1e5631;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="772" y="238" width="764" height="448" as="geometry"/></mxCell><mxCell id="9604_18" value="RUN CONTRACT (R3) — run_config.json → result.json + evidence   ·   the swap seam (every driver, incl. Cisco, plugs here)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;fontColor=#8a2a25;" vertex="1" parent="1"><mxGeometry x="788" y="274" width="732" height="38" as="geometry"/></mxCell><mxCell id="9604_19" value="Cat 1 · Test (V1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="788" y="316" width="140" height="42" as="geometry"/></mxCell><mxCell id="9604_20" value="Cat 2 · Exposure (V1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="936" y="316" width="140" height="42" as="geometry"/></mxCell><mxCell id="9604_21" value="Cat 3 · Remediation (P3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#b3b3b3;dashed=1;fontColor=#8c8c8c;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1084" y="316" width="140" height="42" as="geometry"/></mxCell><mxCell id="9604_22" value="Cat 4 · Resilience (P3)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#b3b3b3;dashed=1;fontColor=#8c8c8c;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1232" y="316" width="140" height="42" as="geometry"/></mxCell><mxCell id="9604_23" value="Cat 5 · Governance (P2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f0f0f0;strokeColor=#b3b3b3;dashed=1;fontColor=#8c8c8c;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1380" y="316" width="140" height="42" as="geometry"/></mxCell>