<mxfile host="app.diagrams.net" agent="claude-code" version="24.7.17"><diagram name="V1 Reference Architecture (Forward-Deployed) — FINAL" id="V1_Reference_Architecture_(Forward-Deployed)_—_FINAL"><mxGraphModel dx="1420" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1600" pageHeight="1160" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="9604_1" value="Enterprise Harness Platform — V1 Reference Architecture (Forward-Deployed) · FINAL" style="text;html=1;fontSize=20;fontStyle=1;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="18" width="1140" height="30" as="geometry"/></mxCell><mxCell id="9604_2" value="Decisions locked: orchestrate-above Cisco · AT&amp;T-owned Model Router · V1a synthetic → V1b bounded-real · adapter ≠ router · aligned R1–R9 / A1–A10" style="text;html=1;fontSize=12;align=left;fontColor=#555555;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="48" width="1150" height="20" as="geometry"/></mxCell><mxCell id="9604_3" value="LEGEND — solid = V1 (a: synthetic mock → b: bounded real · isolated · read-only · no-egress · C5 stability).   Greyed/dashed = Phase 2/3 (deferred).   Blue-dashed = AT&amp;T-owned." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#cccccc;dashed=1;fontSize=10;align=left;verticalAlign=top;fontColor=#555555;spacingLeft=8;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="1200" y="16" width="352" height="60" as="geometry"/></mxCell><mxCell id="9604_4" value="FORWARD-DEPLOYED BOUNDARY — inside the AT&amp;T environment · provider-independent · V1a synthetic → V1b bounded-real · default-deny egress" style="rounded=1;whiteSpace=wrap;html=1;dashed=1;fillColor=none;strokeColor=#9673a6;strokeWidth=2;verticalAlign=top;align=left;fontStyle=2;fontColor=#6a4a86;spacingLeft=10;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="24" y="82" width="1512" height="848" as="geometry"/></mxCell><mxCell id="9604_5" value="SOURCES   ·   Hosted LLM · Databricks · Anthropic (Claude) · AWS Bedrock · Open-Source · Internal AIRS / Janus" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;" vertex="1" parent="1"><mxGeometry x="48" y="110" width="1464" height="38" as="geometry"/></mxCell><mxCell id="9604_6" value="AT&amp;T MODEL ROUTER  (AT&amp;T-owned infra — e.g. Prisma AIRS / Databricks / Internal) — routes production model requests.   We integrate; we do not own it." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;dashed=1;fontSize=11;fontStyle=2;fontColor=#2b5591;" vertex="1" parent="1"><mxGeometry x="48" y="152" width="1464" height="34" as="geometry"/></mxCell><mxCell id="9604_7" value="ADAPTER / LiteLLM — OUR single harness I/O path (R2 · A2).   adapter ≠ Model Router.   Frontier: Anthropic Claude Agent SDK + MCP · Bedrock / Vertex" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;fontStyle=1;fontColor=#8a2a25;" vertex="1" parent="1"><mxGeometry x="48" y="190" width="1464" height="34" as="geometry"/></mxCell><mxCell id="9604_8" value="CONTROL PLANE — deterministic · authoritative gate   (R1 · R4 · R5 · R9 · A1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#eef3fc;strokeColor=#6c8ebf;verticalAlign=top;align=center;fontStyle=1;fontSize=13;fontColor=#1f3b73;spacingTop=6;" vertex="1" parent="1"><mxGeometry x="48" y="238" width="700" height="448" as="geometry"/></mxCell><mxCell id="9604_9" value="Discovery + Provenance — asset key · hash · lineage (§6.1/6.2)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1"><mxGeometry x="64" y="274" width="668" height="40" as="geometry"/></mxCell><mxCell id="9604_10" value="Security Agent / Quarantine — SBOM · secrets · malware · license · policy · sandbox   →  ⟦Security Pass⟧ (W-B)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#da