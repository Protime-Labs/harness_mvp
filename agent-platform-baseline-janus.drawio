  <diagram id="p5-client" name="5 · Client &amp; Channel Configuration">
    <mxGraphModel dx="1600" dy="1000" grid="0" page="1" pageWidth="1600" pageHeight="900">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <mxCell id="k_t" value="&lt;b&gt;Client &amp;amp; Channel Configuration — Web Session Flow, Messaging Pairing, Key Management&lt;/b&gt;" style="text;html=1;fontSize=15;fontColor=#1F3864;align=left;" vertex="1" parent="1">
          <mxGeometry x="40" y="10" width="1000" height="30" as="geometry" />
        </mxCell>
        <mxCell id="k1" value="&lt;b&gt;Browser client&lt;/b&gt;&lt;br&gt;{APP_DOMAIN} embeds agent UI via iframe&lt;br&gt;session token in URL fragment (never logged)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#1F3864;fontSize=11;" vertex="1" parent="1"><mxGeometry x="60" y="70" width="280" height="80" as="geometry" /></mxCell>
        <mxCell id="k2" value="&lt;b&gt;nginx wildcard vhost&lt;/b&gt;&lt;br&gt;{tenant}.agents.{DOMAIN}&lt;br&gt;CSP frame-ancestors → {APP_DOMAIN} + localhost dev · rate zone burst 50" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#1F3864;fontSize=11;" vertex="1" parent="1"><mxGeometry x="400" y="70" width="300" height="80" as="geometry" /></mxCell>
        <mxCell id="k3" value="&lt;b&gt;auth_request /_resolve&lt;/b&gt;&lt;br&gt;provisioner validates token, returns X-Ttyd-Port / X-Gateway-Port,&lt;br&gt;auto-starts exited containers" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E1D5E7;strokeColor=#9673A6;fontSize=11;" vertex="1" parent="1"><mxGeometry x="760" y="70" width="300" height="80" as="geometry" /></mxCell>
        <mxCell id="k4" value="&lt;b&gt;Tenant container&lt;/b&gt;&lt;br&gt;ttyd 127.0.0.1:19000+2N (terminal)&lt;br&gt;gateway WS 127.0.0.1:19000+2N+1 (24 h read timeout)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="1120" y="70" width="320" height="80" as="geometry" /></mxCell>
        <mxCell id="ke1" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#546E7A;" edge="1" parent="1" source="k1" target="k2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ke2" value="every request" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#9673A6;dashed=1;" edge="1" parent="1" source="k2" target="k3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ke3" value="proxy on allow" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;fontSize=9;strokeColor=#546E7A;" edge="1" parent="1" source="k3" target="k4"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="k5" value="&lt;b&gt;Messaging client — Telegram&lt;/b&gt;&lt;br&gt;per-tenant bot token stored in volume .env, synced to config at boot; DM policy per platform pairing model" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#1F3864;fontSize=11;" vertex="1" parent="1"><mxGeometry x="60" y="210" width="320" height="80" as="geometry" /></mxCell>
        <mxCell id="k6" value="&lt;b&gt;Messaging client — WhatsApp&lt;/b&gt;&lt;br&gt;QR pairing via bridge /qr endpoint; group listener writes inbound to state backend" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#DAE8FC;strokeColor=#1F3864;fontSize=11;" vertex="1" parent="1"><mxGeometry x="420" y="210" width="320" height="80" as="geometry" /></mxCell>
        <mxCell id="k7" value="&lt;b&gt;Channel bridge :18795&lt;/b&gt;&lt;br&gt;inbound only by default —&lt;br&gt;ALL outbound messages route through the HITL approval queue (approve-to-act)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#D5E8D4;strokeColor=#82B366;fontSize=11;" vertex="1" parent="1"><mxGeometry x="800" y="210" width="320" height="80" as="geometry" /></mxCell>
        <mxCell id="ke4" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#546E7A;" edge="1" parent="1" source="k5" target="k7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="ke5" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;strokeColor=#546E7A;" edge="1" parent="1" source="k6" target="k7"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="k8" value="&lt;b&gt;Key management — BYOK vs platform&lt;/b&gt;&lt;br&gt;&lt;br&gt;PLATFORM_KEY_HASH comparison at boot detects key type:&lt;br&gt;· Platform key → model &lt;b&gt;pinned&lt;/b&gt; to default cost tier ({DEFAULT_MODEL})&lt;br&gt;· BYOK → free model choice &lt;b&gt;within allowlist&lt;/b&gt;&lt;br&gt;&lt;br&gt;Model allowlist (placeholder tiers): {haiku-class default} · {sonnet-class} · {opus-class} · {gemini-class} · {gpt-class}&lt;br&gt;&lt;br&gt;Fresh gateway token (token_hex(24)) minted per provision; BYOK + gateway tokens persist in host token store across re-image." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFE6CC;strokeColor=#D79B00;fontSize=11;align=left;spacing=10;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="60" y="340" width="520" height="230" as="geometry" /></mxCell>
        <mxCell id="k9" value="&lt;b&gt;Janus client-plane controls&lt;/b&gt;&lt;br&gt;&lt;br&gt;· Session tokens never appear in logs or spans (redaction rule)&lt;br&gt;· iframe origin lock is a control, not cosmetics — prevents UI embedding by untrusted origins&lt;br&gt;· Per-tenant rate zones at nginx = first-line DoS + abuse throttle&lt;br&gt;· WS gateway sessions emit OTel spans (session start/end, tool activity)&lt;br&gt;· Channel identity binding: one bot token / one paired device per tenant — pairing changes are audit events&lt;br&gt;· Client has NO direct path to MCP sidecar, state backend, or inference — everything transits the gateway" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#F3EBF7;strokeColor=#9673A6;fontSize=11;align=left;spacing=10;verticalAlign=top;" vertex="1" parent="1"><mxGeometry x="620" y="340" width="560" height="230" as="geometry" /></mxCell>
        <mxCell id="k10" value="&lt;b&gt;Placeholder map (target environment)&lt;/b&gt;&lt;br&gt;{HOST_ID} host name · {HOST_IP} public IP · {DOMAIN} base domain · {APP_DOMAIN} console origin · {TENANT_ID} tenant uuid · {LOCAL_MODEL} pinned GPU model · {GPU_MODEL} 24 GB-class card · {STATE_DB} Postgres+RLS backend · {CONFIG_REPO} private git config repo · {N_TOOLS} MCP tool modules · {N_SKILLS} workspace skills · {PINNED_VERSION} agent runtime version · {OVERFLOW_HOST} secondary provisioner · {PLATFORM_LLM} frontier API provider" style="shape=note;whiteSpace=wrap;html=1;fillColor=#FFF2CC;strokeColor=#D6B656;fontSize=10;align=left;spacing=8;" vertex="1" parent="1"><mxGeometry x="60" y="600" width="1120" height="120" as="geometry" /></mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
