        <mxCell id="xuN6nkz0luSvyYvwZrO3-25" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=19;fontStyle=1;fontColor=#1f1f1f;align=center;verticalAlign=top;spacingTop=14;spacing=10;dashed=0;shadow=0;" value="Layer 1 — Test Harnesses" vertex="1">
          <mxGeometry height="1225" width="450" x="200" y="420" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-26" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=19;fontStyle=1;fontColor=#1f1f1f;align=center;verticalAlign=top;spacingTop=14;spacing=10;dashed=0;shadow=0;" value="Layer 2 — Exposure Harnesses" vertex="1">
          <mxGeometry height="1225" width="450" x="690" y="420" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-27" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=19;fontStyle=1;fontColor=#1f1f1f;align=center;verticalAlign=top;spacingTop=14;spacing=10;dashed=0;shadow=0;" value="Layer 3 — Remediation Harnesses" vertex="1">
          <mxGeometry height="1225" width="450" x="1180" y="420" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-28" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=19;fontStyle=1;fontColor=#1f1f1f;align=center;verticalAlign=top;spacingTop=14;spacing=10;dashed=0;shadow=0;" value="Layer 4 — Resilience Harnesses" vertex="1">
          <mxGeometry height="1225" width="450" x="1670" y="420" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-29" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=19;fontStyle=1;fontColor=#1f1f1f;align=center;verticalAlign=top;spacingTop=14;spacing=10;dashed=0;shadow=0;" value="Layer 5 — Governance Harnesses" vertex="1">
          <mxGeometry height="1225" width="450" x="2160" y="420" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-30" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;1. Model Behavior &amp;amp; Capability Benchmark Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Validates baseline quality across reasoning, coding, multimodal, tool-use, latency, throughput, cost, and open-weight compatibility.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: scorecard, pass/fail thresholds, model compatibility matrix&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="225" y="490" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-31" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;2. Adversarial Robustness &amp;amp; Red-Team Scenario Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Runs jailbreaks, refusal-bypass attempts, stress prompts, malformed inputs, and adversarial scenario suites.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: adversarial risk score, exploit examples, mitigation notes&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="225" y="770" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-32" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;3. Safety / Policy / Harm Evaluation Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Checks unsafe output, harmful instructions, policy conformance, protected-class sensitivity, and controlled content boundaries.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: safety verdict, blocked categories, evidence artifacts&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="225" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-33" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#6c8ebf;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;4. Hallucination &amp;amp; Grounding Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Tests factuality, grounded answers, citation quality, RAG support, uncertainty handling, and answer consistency.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: grounding score, source mismatch findings, regression set&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="225" y="1330" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-34" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;1. Prompt-Injection &amp;amp; Tool-Abuse Exposure Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Tests direct/indirect prompt injection, MCP/tool boundary abuse, unauthorized tool invocation, and agent instruction override.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: exposure chain, affected tool, required policy control&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="715" y="490" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-35" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;2. Exploit Chain &amp;amp; Cyber Misuse Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Assesses model-assisted cyber capability misuse, exploit-chain generation, unsafe code execution paths, and dual-use escalation.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: cyber misuse score, chain graph, kill-switch recommendation&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="715" y="770" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-36" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;3. Data Privacy &amp;amp; Leakage Exposure Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Checks PII/CPNI/secrets leakage, training/retention assumptions, RAG leakage, embeddings leakage, and cross-context disclosure.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: data exposure severity, data-class mapping, remediation action&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="715" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-37" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#d6b656;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;4. Context &amp;amp; Business-Impact Validation Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Validates use-case context, asset criticality, business impact, operational blast radius, and safe routing decisions.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: business-impact tier, model-router constraint, compensating controls&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="715" y="1330" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-38" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;1. Safe Remediation Execution Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Constrains automated fixes to approved actions, checks privileges, validates change preconditions, and avoids unsafe self-remediation.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: approved fix path, action evidence, human-approval requirement&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="1205" y="490" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-39" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;2. IaC / Terraform / Playbook Remediation Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Applies approved infrastructure-as-code, guardrail, network, IAM, logging, and policy templates to close gaps.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: change record, control closure, rollback handle&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="1205" y="770" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-40" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;3. Rollback &amp;amp; Retest Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Verifies rollback behavior, regression tests, after-action retest, and before/after evidence capture.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: rollback success, retest verdict, evidence bundle&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="1205" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-41" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#82b366;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;4. Blast-Radius &amp;amp; Change-Risk Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Analyzes dependencies, impacted assets, tool permissions, data paths, and downstream safety/regression impact.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: blast-radius report, risk acceptance or remediation gate&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="1205" y="1330" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-42" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;1. Control-Failure / Degraded-Ops Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Tests fail-open/fail-closed behavior for guardrails, identity, logging, policy service, network egress, and evidence store.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: degraded-mode verdict, fail-safe gaps, runbook updates&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="1695" y="490" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-43" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;2. Failover &amp;amp; Recovery / RTO-RPO Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Measures provider/model/runtime failover, fallback model selection, state recovery, and RTO/RPO targets.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: recovery metrics, fallback route, model availability score&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="1695" y="770" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-44" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;3. Agent Coordination / Heartbeat Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Cisco-style coordination checks for agent heartbeat, watchdogs, stale-agent detection, auto-block, and auto-stop behavior.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: coordination health score, blocked agent/task, heartbeat evidence&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="1695" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-45" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#9673a6;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;4. Latency / Throughput / Cost Budget Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Tests overload, budget caps, rate limits, token exhaustion, queueing, throttling, and cost-aware routing.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: SLO report, cost guardrail, performance envelope&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="1695" y="1330" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-46" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;1. Finding Lifecycle / Evidence / Verdict Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Cisco-style lifecycle for states, verdicts, severity, reproduction steps, evidence artifacts, and artifact/agent fingerprints.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: immutable finding record, verdict, evidence package&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="2185" y="490" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-47" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;2. Auditability &amp;amp; Explainability Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Captures model/tool/agent traces, rationale, explainability artifacts, reviewer notes, and end-to-end action history.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: audit trail, explanation bundle, reviewer view&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="2185" y="770" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-48" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;3. Policy Compliance / Golden Controls Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Maps results to AT&amp;amp;T Golden Controls, ISO 42001, LLM/agentic threat models, data policy, and security exceptions.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: control coverage, gap report, approval recommendation&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="2185" y="1050" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-49" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#b85450;fontSize=19;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;4. Human Approval &amp;amp; Model Risk Gate Harness&lt;/b&gt;&lt;br&gt;&lt;span&gt;Manages HITL approval, exception workflows, risk acceptance, high-risk tool/model approval, and compensating controls.&lt;/span&gt;&lt;br&gt;&lt;span style=&quot;color: rgb(102, 102, 102);&quot;&gt;Outputs: approval record, conditional pass, expiration/retest date&lt;/span&gt;" vertex="1">
          <mxGeometry height="230" width="400" x="2185" y="1330" as="geometry" />
        </mxCell>
        <mxCell id="xuN6nkz0luSvyYvwZrO3-50" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=27;fontColor=#1f1f1f;fontStyle=0;align=left;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="&lt;b&gt;Packaging model:&lt;/b&gt; Each harness can be tagged as &lt;b&gt;Foundational&lt;/b&gt;, &lt;b&gt;Advanced Capability&lt;/b&gt;, or &lt;b&gt;AT&amp;amp;T Context Pack&lt;/b&gt;. Foundational packs are common across all models; advanced packs cover reasoning/cyber/coding/multimodal/tool/MCP/agentic needs; AT&amp;amp;T context packs embed Golden Controls, data policy, business-impact rules, prior findings, and approved remediation playbooks." vertex="1">
          <mxGeometry height="150" width="2370" x="210" y="1660" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
