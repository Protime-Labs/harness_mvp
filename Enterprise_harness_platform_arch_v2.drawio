        <mxCell id="xuN6nkz0luSvyYvwZrO3-21" parent="1" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#999999;fontSize=20;fontColor=#1f1f1f;fontStyle=0;align=center;verticalAlign=middle;spacing=8;spacingTop=6;spacingBottom=6;shadow=0;" value="Open-weight availability" vertex="1">
