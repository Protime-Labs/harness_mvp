        <mxCell id="mat4" value="high-risk use-case" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#607D8B;fontColor=#263238;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="820" y="110" width="260" height="40" as="geometry"/></mxCell>
        <mxCell id="mat5" value="HIGH trust model" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#607D8B;fontColor=#263238;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="360" y="150" width="200" height="70" as="geometry"/></mxCell>
        <mxCell id="mat6" value="light" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B0BEC5;fontColor=#37474F;" vertex="1" parent="1"><mxGeometry x="560" y="150" width="260" height="70" as="geometry"/></mxCell>
        <mxCell id="mat7" value="risk-tier pack" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B0BEC5;fontColor=#37474F;" vertex="1" parent="1"><mxGeometry x="820" y="150" width="260" height="70" as="geometry"/></mxCell>
        <mxCell id="mat8" value="UNTRUSTED model" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ECEFF1;strokeColor=#607D8B;fontColor=#263238;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="360" y="220" width="200" height="70" as="geometry"/></mxCell>
        <mxCell id="mat9" value="risk-tier pack + escalation" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFFFF;strokeColor=#B0BEC5;fontColor=#37474F;" vertex="1" parent="1"><mxGeometry x="560" y="220" width="260" height="70" as="geometry"/></mxCell>
        <mxCell id="mat10" value="FULL battery + stricter gate" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFEBEE;strokeColor=#C62828;fontColor=#B71C1C;fontStyle=1;" vertex="1" parent="1"><mxGeometry x="820" y="220" width="260" height="70" as="geometry"/></mxCell>
        <mxCell id="mat11" value="lower trust only ADDS harnesses + tightens the gate — never subtracts (A11 monotonicity on the trust axis)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#6D4C41;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="360" y="300" width="720" height="40" as="geometry"/></mxCell>
        <mxCell id="mat12" value="MODE: operations  (regular runtime)

• inline guardrail on live traffic
• deterministic detectors + critical criteria subset
• detector floor only (no LLM judge on hot path)
• budget-tight · low latency
• gate: allow / block inline" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#E3F2FD;strokeColor=#1976D2;fontColor=#0D47A1;" vertex="1" parent="1"><mxGeometry x="300" y="400" width="380" height="260" as="geometry"/></mxCell>
        <mxCell id="mat13" value="MODE: assurance  (testing modules)

• offline red-team, isolated + synthetic (R7/A6)
• full adversarial battery
• N independent judges (A4/A5) + detector floor
• full budget (A8/C6)
• gate: approve/warn/block/manual_review + evidence bundle" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#FFF3E0;strokeColor=#F57C00;fontColor=#E65100;" vertex="1" parent="1"><mxGeometry x="760" y="400" width="380" height="260" as="geometry"/></mxCell>
        <mxCell id="mat14" value="SAME control plane governs both — the mode selects the criteria profile and whether the judge quorum runs. No LLM in the gate/risk path in either mode (A1)." style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFFDE7;strokeColor=#F9A825;fontColor=#6D4C41;align=left;spacingLeft=8;" vertex="1" parent="1"><mxGeometry x="300" y="690" width="840" height="50" as="geometry"/></mxCell>
      </root></mxGraphModel>
  </diagram>
