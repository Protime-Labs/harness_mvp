  <diagram id="mat" name="2 · Trust × Risk + Modes">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" page="1" pageWidth="1600" pageHeight="1000"><root><mxCell id="0"/><mxCell id="1" parent="0"/>
        <mxCell id="mat1" value="Two axes negotiate the posture; two modes apply it" style="text;html=1;strokeColor=none;fillColor=none;align=center;fontStyle=1;fontSize=20;fontColor=#212121;" vertex="1" parent="1"><mxGeometry x="480" y="20" width="520" height="34" as="geometry"/></mxCell>
