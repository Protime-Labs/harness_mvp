="1" as="geometry"/></mxCell><mxCell id="c16" value="Persistent Memory&amp;#10;markdown files across sessions" style="fillColor=#FEF3D9;strokeColor=#B7791F;fontColor=#7A5200;" vertex="1" parent="1"><mxGeometry x="120" y="570" width="250" height="66" as="geometry"/></mxCell><mxCell id="c17" value="⚠ Memory poisoning" style="fillColor=#FBE5E8;strokeColor=#D0293E;fontColor=#9B1B2E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="145" y="640" width="200" height="24" as="geometry"/></mxCell><mxCell id="c18" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B6376;fontSize=10;" edge="1" parent="1" source="c3" target="c16"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c19" value="Self-Modifying Skills&amp;#10;pulled from public registries" style="fillColor=#FEF3D9;strokeColor=#B7791F;fontColor=#7A5200;" vertex="1" parent="1"><mxGeometry x="300" y="740" width="250" height="66" as="geometry"/></mxCell><mxCell id="c20" value="⚠ Live supply-chain surface" style="fillColor=#FBE5E8;strokeColor=#D0293E;fontColor=#9B1B2E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="325" y="810" width="200" height="24" as="geometry"/></mxCell><mxCell id="c21" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B6376;fontSize=10;" edge="1" parent="1" source="c3" target="c19"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c22" value="Cron Scheduler&amp;#10;unattended recurring tasks" style="fillColor=#FEF3D9;strokeColor=#B7791F;fontColor=#7A5200;" vertex="1" parent="1"><mxGeometry x="650" y="760" width="250" height="66" as="geometry"/></mxCell><mxCell id="c23" value="⚠ Persistence" style="fillColor=#FBE5E8;strokeColor=#D0293E;fontColor=#9B1B2E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="675" y="830" width="200" height="24" as="geometry"/></mxCell><mxCell id="c24" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B6376;fontSize=10;" edge="1" parent="1" source="c3" target="c22"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c25" value="Sub-agent Spawning&amp;#10;isolated child agents" style="fillColor=#FEF3D9;strokeColor=#B7791F;fontColor=#7A5200;" vertex="1" parent="1"><mxGeometry x="1010" y="580" width="250" height="66" as="geometry"/></mxCell><mxCell id="c26" value="⚠ Sub-agent sprawl (uncapped)" style="fillColor=#FBE5E8;strokeColor=#D0293E;fontColor=#9B1B2E;fontSize=10;" vertex="1" parent="1"><mxGeometry x="1035" y="650" width="200" height="24" as="geometry"/></mxCell><mxCell id="c27" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B6376;fontSize=10;" edge="1" parent="1" source="c3" target="c25"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="p2" name="2 · Reference Architecture"><mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageWidth="1500" pageHeight="1000" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c28" value="2 · Reference Architecture — detectable framework" style="text;html=1;fontStyle=1;fontSize=20;fontColor=#1a1e29;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1100" height="40" as="geometry"/></mxCell><mxCell id="c29" value="Every agent-relevant flow traverses the controlled egress layer; agents run ONLY in a hardened enclave — anywhere else is a detection target." style="text;html=1;fontSize=12;fontColor=#5b6376;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="60" width="1300" height="24" as="geometry"/></mxCell><mxCell id="c30" value="Untrusted External Tier" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacing=8;fillColor=#FDE7E9;strokeColor=#C0392B;fontColor=#7B241C;" vertex="1" parent="1"><mxGeometry x="60" y="120" width="360" height="470" as="geometry"/></mxCell><mxCell id="c31" value="Model Providers&amp;#10;OpenRouter · NIM · vendor · self-hosted" style="fillColor=#FDE7E9;strokeColor=#C0392B;fontColor=#7B241C;" vertex="1" parent="1"><mxGeometry x="90" y="170" width="300" height="56" as="geometry"/></mxCell><mxCell id="c32" value="Messaging Platforms&amp;#10;Telegram · Discord · Slack · Signal" style="fillColor=#FDE7E9;strokeColor=#C0392B;fontColor=#7B241C;" vertex="1" parent="1"><mxGeometry x="90" y="246" width="300" height="56" as="geometry"/></mxCell><mxCell id="c33" value="Public Skill / MCP Sources&amp;#10;registries · sidecar tool servers" style="fillColor=#FDE7E9;strokeColor=#C0392B;fontColor=#7B241C;" vertex="1" parent="1"><mxGeometry x="90" y="322" width="300" height="56" as="geometry"/></mxCell><mxCell id="c34" value="Assume breach — treat any browsed / ingested content as adversarial on every turn." style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=left;verticalAlign=top;dashed=1;fillColor=#FBFBFE;strokeColor=#8b93a6;fontColor=#5b6376;" vertex="1" parent="1"><mxGeometry x="90" y="410" width="300" height="60" as="geometry"/></mxCell><mxCell id="c35" value="Controlled Egress Layer (default-deny)" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacing=8;fillColor=#FEF3D9;strokeColor=#B7791F;fontColor=#7A5200;" vertex="1" parent="1"><mxGeometry x="470" y="120" width="300" height="470" as="geometry"/></mxCell><mxCell id="c36" value="Inspecting Proxy&amp;#10;+ DNS allowlist" style="fillColor=#FEF3D9;strokeColor=#B7791F;fontColor=#7A5200;" vertex="1" parent="1"><mxGeometry x="500" y="180" width="240" height="56" as="geometry"/></mxCell><mxCell id="c37" value="DLP / prompt-level redaction" style="fillColor=#FEF3D9;strokeColor=#B7791F;fontColor=#7A5200;" vertex="1" parent="1"><mxGeometry x="500" y="256" width="240" height="44" as="geometry"/></mxCell><mxCell id="c38" value="Per-request wrappers&amp;#10;(LiteLLM model gateway)" style="fillColor=#FEF3D9;strokeColor=#B7791F;fontColor=#7A5200;" vertex="1" parent="1"><mxGeometry x="500" y="320" width="240" height="56" as="geometry"/></mxCell><mxCell id="c39" value="Mediate, don't block — egress &amp;amp; messaging are core functions; inspect &amp;amp; allowlist at the chokepoint." style="rounded=1;whiteSpace=wrap;html=1;fontSize=10;align=left;verticalAlign=top;dashed=1;fillColor=#FBFBFE;strokeColor=#8b93a6;fontColor=#5b6376;" vertex="1" parent="1"><mxGeometry x="500" y="410" width="240" height="90" as="geometry"/></mxCell><mxCell id="c40" value="Corporate Environment" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacing=8;fillColor=#E4F4EC;strokeColor=#12925A;fontColor=#0B5138;" vertex="1" parent="1"><mxGeometry x="820" y="120" width="640" height="640" as="geometry"/></mxCell><mxCell id="c41" value="Hardened Enclave — sanctioned agents" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacing=8;fillColor=#DFF0FB;strokeColor=#2C6FB0;fontColor=#194b75;" vertex="1" parent="1"><mxGeometry x="850" y="170" width="400" height="330" as="geometry"/></mxCell><mxCell id="c42" value="Rootless, network-restricted sandbox&amp;#10;no host mounts · least privilege" style="fillColor=#DFF0FB;strokeColor=#2C6FB0;fontColor=#194b75;" vertex="1" parent="1"><mxGeometry x="875" y="215" width="350" height="50" as="geometry"/></mxCell><mxCell id="c43" value="Per-agent machine identity&amp;#10;scoped creds (never shared / human keys)" style="fillColor=#DFF0FB;strokeColor=#2C6FB0;fontColor=#194b75;" vertex="1" parent="1"><mxGeometry x="875" y="275" width="350" height="50" as="geometry"/></mxCell><mxCell id="c44" value="Default-deny tools / MCP&amp;#10;policy-evaluated at call time" style="fillColor=#DFF0FB;strokeColor=#2C6FB0;fontColor=#194b75;" vertex="1" parent="1"><mxGeometry x="875" y="335" width="350" height="50" as="geometry"/></mxCell><mxCell id="c45" value="HITL approval for high-impact actions" style="fillColor=#DFF0FB;strokeColor=#2C6FB0;fontColor=#194b75;" vertex="1" parent="1"><mxGeometry x="875" y="395" width="350" height="44" as="geometry"/></mxCell><mxCell id="c46" value="Full Auditability → tamper-evident store&amp;#10;every model call &amp;amp; policy decision logged (un-logged = control failure)" style="fillColor=#E0F2F1;strokeColor=#0F766E;fontColor=#0A4A45;" vertex="1" parent="1"><mxGeometry x="850" y="530" width="400" height="60" as="geometry"/></mxCell><mxCell id="c47" value="Shadow / Unsanctioned Agents&amp;#10;&amp;#10;no monitoring&amp;#10;DETECTION TARGET" style="fillColor=#FBE5E8;strokeColor=#D0293E;fontColor=#9B1B2E;fontSize=10;verticalAlign=middle;align=center;" vertex="1" parent="1"><mxGeometry x="1290" y="200" width="150" height="300" as="geometry"/></mxCell><mxCell id="c48" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B6376;fontSize=10;" edge="1" parent="1" source="c31" target="c36"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c49" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B6376;fontSize=10;" edge="1" parent="1" source="c32" target="c36"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c50" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B6376;fontSize=10;" edge="1" parent="1" source="c33" target="c36"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c51" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B6376;fontSize=10;" edge="1" parent="1" source="c36" target="c37"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c52" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B6376;fontSize=10;" edge="1" parent="1" source="c37" target="c38"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c53" value="inspected + allowlisted" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#12925A;fontSize=10;fontColor=#0B5138;" edge="1" parent="1" source="c38" target="c42"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c54" value="evidence" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#12925A;fontSize=10;fontColor=#0B5138;" edge="1" parent="1" source="c45" target="c46"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c55" value="detected" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#D0293E;dashed=1;fontSize=10;fontColor=#9B1B2E;" edge="1" parent="1" source="c47" target="c46"><mxGeometry relative="1" as="geometry"/></mxCell></root></mxGraphModel></diagram><diagram id="p3" name="3 · Detection Pipeline"><mxGraphModel dx="1200" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageWidth="1500" pageHeight="1000" math="0" shadow="0"><root><mxCell id="0"/><mxCell id="1" parent="0"/><mxCell id="c56" value="3 · Detection Pipeline — host + network + behavioral → SIEM → response" style="text;html=1;fontStyle=1;fontSize=20;fontColor=#1a1e29;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="20" width="1150" height="40" as="geometry"/></mxCell><mxCell id="c57" value="First operational question: are agents already running here? Combine indicators into SIEM analytics mapped to response." style="text;html=1;fontSize=12;fontColor=#5b6376;align=left;verticalAlign=middle;" vertex="1" parent="1"><mxGeometry x="40" y="60" width="1200" height="24" as="geometry"/></mxCell><mxCell id="c58" value="Host Indicators" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacing=8;fillColor=#F1F3F7;strokeColor=#5B6376;fontColor=#2b3040;" vertex="1" parent="1"><mxGeometry x="60" y="130" width="360" height="250" as="geometry"/></mxCell><mxCell id="c59" value="Install / state paths — ~/.openclaw, ~/.hermes, %LOCALAPPDATA%\hermes; SOUL.md · MEMORY.md · USER.md" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="85" y="175" width="310" height="60" as="geometry"/></mxCell><mxCell id="c60" value="Runtime — uv-managed .venv, outbound websockets, portable Git (MinGit)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="85" y="245" width="310" height="55" as="geometry"/></mxCell><mxCell id="c61" value="Dependency traces — ripgrep · ffmpeg · node.js in user profile" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="85" y="310" width="310" height="50" as="geometry"/></mxCell><mxCell id="c62" value="Network Indicators" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacing=8;fillColor=#F1F3F7;strokeColor=#5B6376;fontColor=#2b3040;" vertex="1" parent="1"><mxGeometry x="60" y="410" width="360" height="250" as="geometry"/></mxCell><mxCell id="c63" value="Model-provider egress — OpenRouter · NIM · vendor portals (no sanctioned use case)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="85" y="455" width="310" height="55" as="geometry"/></mxCell><mxCell id="c64" value="Messaging beacons — persistent Telegram / Discord / Slack / Signal (control channel)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="85" y="520" width="310" height="55" as="geometry"/></mxCell><mxCell id="c65" value="Local MCP loopback ports + outbound tool traffic (sidecar); off-hours bursts (cron)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="85" y="585" width="310" height="60" as="geometry"/></mxCell><mxCell id="c66" value="Behavioral Analytics" style="rounded=0;whiteSpace=wrap;html=1;verticalAlign=top;align=left;fontStyle=1;fontSize=13;spacing=8;fillColor=#F1F3F7;strokeColor=#5B6376;fontColor=#2b3040;" vertex="1" parent="1"><mxGeometry x="60" y="690" width="360" height="200" as="geometry"/></mxCell><mxCell id="c67" value="Autonomous off-hours file / net / process activity (no interactive login)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="85" y="735" width="310" height="55" as="geometry"/></mxCell><mxCell id="c68" value="Tool-call bursts &amp;amp; process fan-out (sub-agent sprawl)" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="85" y="795" width="310" height="45" as="geometry"/></mxCell><mxCell id="c69" value="Self-modification — process writes then executes its own scripts" style="rounded=1;whiteSpace=wrap;html=1;shadow=1;fontSize=12;" vertex="1" parent="1"><mxGeometry x="85" y="845" width="310" height="40" as="geometry"/></mxCell><mxCell id="c70" value="SIEM Correlation&amp;#10;XSIAM / Cribl&amp;#10;&amp;#10;host + network + behavior&amp;#10;→ agent detection analytics" style="fillColor=#E7EAFD;strokeColor=#4F46E5;fontColor=#2A247A;" vertex="1" parent="1"><mxGeometry x="560" y="430" width="300" height="160" as="geometry"/></mxCell><mxCell id="c71" value="Response Actions&amp;#10;&amp;#10;isolate host · revoke tokens&amp;#10;kill process + crons&amp;#10;scrub keys / memory&amp;#10;open ServiceNow ticket" style="fillColor=#E0F2F1;strokeColor=#0F766E;fontColor=#0A4A45;" vertex="1" parent="1"><mxGeometry x="960" y="430" width="320" height="160" as="geometry"/></mxCell><mxCell id="c72" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B6376;fontSize=10;" edge="1" parent="1" source="c58" target="c70"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c73" value="" style="edgeStyle=orthogonalEdgeStyle;rounded=1;html=1;endArrow=block;strokeColor=#5B6376;fontSize=10;" edge="1" parent="1" source="c62" target="c70"><mxGeometry relative="1" as="geometry"/></mxCell><mxCell id="c74" value="" style="edge